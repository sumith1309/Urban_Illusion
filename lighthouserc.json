{
  "_doc": "Performance gate for Urban Illusion. Settled with the user 2026-05-23: DevTools-observed throttling on the slow-4G + 4× CPU profile is the LCP source of truth — Lantern is captured alongside as an early-warning signal for JS-bundle bloat, not as a blocker. Both numbers are recorded at every phase checkpoint.",

  "ci": {
    "collect": {
      "startServerCommand": "pnpm start",
      "startServerReadyPattern": "Ready in",
      "url": ["http://localhost:3000/"],
      "numberOfRuns": 3,
      "settings": {
        "formFactor": "mobile",
        "throttlingMethod": "devtools",
        "screenEmulation": {
          "mobile": true,
          "width": 412,
          "height": 915,
          "deviceScaleFactor": 1.75,
          "disabled": false
        },
        "throttling": {
          "rttMs": 150,
          "throughputKbps": 1638.4,
          "cpuSlowdownMultiplier": 4,
          "requestLatencyMs": 0,
          "downloadThroughputKbps": 1638.4,
          "uploadThroughputKbps": 750
        }
      }
    },

    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "_": "Core gate — DevTools real throttling",
        "categories:performance":     ["error", { "minScore": 0.9 }],
        "categories:accessibility":   ["error", { "minScore": 0.9 }],
        "categories:best-practices":  ["error", { "minScore": 0.9 }],
        "categories:seo":             ["error", { "minScore": 0.9 }],

        "__cwv": "Core Web Vitals",
        "largest-contentful-paint":   ["error", { "maxNumericValue": 2000 }],
        "cumulative-layout-shift":    ["error", { "maxNumericValue": 0.1 }],
        "total-blocking-time":        ["error", { "maxNumericValue": 200 }],
        "interaction-to-next-paint":  ["warn",  { "maxNumericValue": 200 }],

        "__bundle": "Bundle-size guardrails — INP/TBT will hurt first when these blow",
        "resource-summary:script:size":     ["error", { "maxNumericValue": 250000 }],
        "resource-summary:script:count":    ["warn",  { "maxNumericValue": 12 }],
        "resource-summary:total:size":      ["warn",  { "maxNumericValue": 500000 }],
        "resource-summary:font:size":       ["warn",  { "maxNumericValue": 120000 }],
        "unused-javascript":                ["warn",  { "maxNumericValue": 50000 }],

        "__discipline": "Architectural guardrails",
        "uses-text-compression":            ["error", { "minScore": 1 }],
        "uses-responsive-images":           ["warn",  { "minScore": 1 }],
        "modern-image-formats":             ["warn",  { "minScore": 1 }],
        "render-blocking-resources":        ["warn",  { "maxNumericValue": 200 }]
      }
    },

    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
